{
    "name": "spaceship/app",
    "description": "Spaceship Symfony application with RabbitMQ",
    "type": "project",
    "license": "MIT",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.2",
        "ext-amqp": "*",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "api-platform/doctrine-orm": "^4.2",
        "api-platform/symfony": "^4",
        "doctrine/doctrine-migrations-bundle": "^4.0",
        "easycorp/easyadmin-bundle": "*",
        "lexik/jwt-authentication-bundle": "^3.2",
        "php-amqplib/php-amqplib": "^3.7",
        "runtime/frankenphp-symfony": "^0.2.0",
        "symfony/amqp-messenger": "7.*",
        "symfony/console": "7.*",
        "symfony/doctrine-messenger": "7.*",
        "symfony/dotenv": "7.*",
        "symfony/expression-language": "7.*",
        "symfony/flex": "^2",
        "symfony/framework-bundle": "7.*",
        "symfony/http-client": "7.*",
        "symfony/lock": "7.*",
        "symfony/messenger": "7.*",
        "symfony/monolog-bundle": "^4.0",
        "symfony/runtime": "7.*",
        "symfony/twig-bundle": "7.*",
        "symfony/yaml": "7.*",
        "twig/twig": "^3.0"
    },
    "require-dev": {
        "doctrine/doctrine-fixtures-bundle": "^4.3",
        "phpunit/phpunit": "^13.0",
        "symfony/browser-kit": "7.*",
        "symfony/css-selector": "7.*",
        "symfony/debug-bundle": "7.*",
        "symfony/maker-bundle": "^1.0",
        "symfony/stopwatch": "7.*",
        "symfony/web-profiler-bundle": "7.*",
        "zenstruck/foundry": "^2.9"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd"
        },
        "post-install-cmd": ["@auto-scripts"],
        "post-update-cmd": ["@auto-scripts"]
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "7.*"
        },
        "runtime": {
            "class": "Runtime\\FrankenPhpSymfony\\Runtime"
        }
    }
}
